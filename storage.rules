rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Архивы - доступны для чтения админам и диспетчерам
    match /archives/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.role == 'admin'
      );
    }

    // Proof of Delivery photos — водитель загружает при закрытии точки.
    // ⚠️ companyId-сегмент пути может содержать пробел/точку ("Y.C. Plast"),
    // из-за чего сверка userData().companyId == companyId давала
    // firebase_storage/unauthorized. Кастомные claims (token.role/companyId)
    // НЕ выставляются, поэтому проверяем только РОЛЬ через cross-service get,
    // без сверки companyId из пути.
    // TODO(multitenant): вернуть привязку к компании через custom claims
    //   (setCustomUserClaims: role, companyId) до мульти-тенант запуска.
    // Proof of Delivery photos. Тенант-привязка через CUSTOM CLAIMS
    // (request.auth.token.companyId/role) — надёжно, без cross-service get,
    // который у проекта не отрабатывал.
    // Переходный период: если companyId-claim ещё не на токене (пользователь не
    // перелогинился / токен не обновлён) — разрешаем авторизованному, как было,
    // чтобы не было регресса. Когда у всех claims проставлены — изоляция строгая.
    match /companies/{companyId}/pod/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.companyId == null ||
        request.auth.token.role == 'super_admin' ||
        request.auth.token.companyId == companyId
      );
      allow write: if request.auth != null
        && request.resource.size < 8 * 1024 * 1024
        && (
          request.auth.token.role == 'super_admin' ||
          request.auth.token.companyId == null ||
          (request.auth.token.companyId == companyId &&
            request.auth.token.role in
              ['driver', 'dispatcher', 'admin', 'owner'])
        );
    }

    // Company-scoped files: only company members can access
    match /companies/{companyId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        request.auth.token.companyId == companyId
      );
      allow write: if request.auth != null && (
        request.auth.token.role == 'super_admin' ||
        (request.auth.token.companyId == companyId && (
          request.auth.token.role == 'admin' ||
          request.auth.token.role == 'dispatcher' ||
          request.auth.token.role == 'warehouse_keeper'
        ))
      );
    }

    // User profile pictures — own only
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.token.role == 'super_admin';
    }
  }
}
