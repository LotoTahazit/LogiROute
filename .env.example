# Google Maps API Keys
# Получите ключи на https://console.cloud.google.com/
GOOGLE_MAPS_WEB_KEY=your_web_api_key_here
GOOGLE_MAPS_ANDROID_KEY=your_android_api_key_here
#
# Куда прописать ключи:
# - Скопируйте этот файл → .env.local (для flutter --dart-define-from-file)
# - Android: GOOGLE_MAPS_API_KEY в android/local.properties (см. local.properties.example)
# Web: подставьте GOOGLE_MAPS_WEB_KEY в web/index.html (или через build_web.sh)
# - Web Push (FCM): FCM_VAPID_KEY из Firebase Console → Cloud Messaging → Web Push certificates
# - iOS: GMSApiKey в ios/Runner/Info.plist

# OSRM (optional; единый источник — lib/config/api_constants.dart)
# OSRM_HOST — только хост, без пути (предпочтительно)
# OSRM_BASE_URL — устаревший вариант: берётся origin (совместимость со старыми .env)
# OSRM_FALLBACK_HOST — второй сервер при отказе основного
# OSRM_HOST=https://router.project-osrm.org
# OSRM_FALLBACK_HOST=https://routing.openstreetmap.de/routed-car
OSRM_BASE_URL=https://router.project-osrm.org/route/v1/driving

# Координаты склада (опционально)
WAREHOUSE_LAT=32.48698
WAREHOUSE_LNG=34.982121

# === Payment Provider (choose one) ===
# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Tranzila (Israel)
# TRANZILA_TERMINAL=your_terminal_name
# TRANZILA_API_KEY=your_api_key

# PayPlus (Israel)
# PAYPLUS_API_KEY=your_api_key
# PAYPLUS_SECRET_KEY=your_secret_key

# === SMTP Email Notifications ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@logiroute.com
