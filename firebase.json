{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "emulators": {
    "firestore": { "port": 8080 },
    "ui": { "enabled": true, "port": 4000 }
  },
  "storage": [
    {
      "bucket": "logiroute-app.firebasestorage.app",
      "rules": "storage.rules"
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/.env",
        "destination": "/.env"
      },
      {
        "source": "/reset-password",
        "destination": "/reset-password.html"
      },
      {
        "source": "/reset-password.html",
        "destination": "/reset-password.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "logiroute-app",
          "appId": "1:375119625021:android:5da3ed489201b45b3f6354",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "logiroute-app",
          "configurations": {
            "android": "1:375119625021:android:5da3ed489201b45b3f6354",
            "ios": "1:375119625021:ios:7d2b2b5b1e8656d43f6354",
            "web": "1:375119625021:web:250eccc94710e0d83f6354"
          }
        }
      }
    }
  }
}